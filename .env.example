# ── Server ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── Redis (BullMQ Job Queue) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Storage ─────────────────────────────────────────────────────────────
# 'local' for development, 's3' for MinIO/S3 production storage
STORAGE_MODE=local

# ── MinIO / S3 (only used when STORAGE_MODE=s3) ────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=eyecon
MINIO_REGION=us-east-1

# ── Transcoding ─────────────────────────────────────────────────────────
SEGMENT_DURATION=4
QUEUE_CONCURRENCY=2
MAX_UPLOAD_SIZE_MB=5120

# ── Security ───────────────────────────────────────────────────────────
STREAM_SECRET=change-this-to-a-random-secret-in-production
TOKEN_EXPIRY_SECONDS=21600

# ── Cleanup ─────────────────────────────────────────────────────────────
CLEANUP_INTERVAL_HOURS=6

# ── Gemini (optional, inherited from original project) ──────────────────
GEMINI_API_KEY=MY_GEMINI_API_KEY
APP_URL=MY_APP_URL
