FROM node:20-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    tini \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev

COPY server.ts ./
COPY src/lib ./src/lib
COPY tsconfig.json ./

RUN mkdir -p uploads streams thumbnails

ENV NODE_ENV=production

ENTRYPOINT ["tini", "--"]
CMD ["npx", "tsx", "src/lib/worker.ts"]
